# Database connection (Use pooler URL on port 5432)
DATABASE_URL="postgresql://username:password@host:port/database"

# Cloudflare R2 Credentials
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="your_r2_bucket_name"
R2_PUBLIC_DOMAIN="https://your-public-domain-or-r2-pub-url.com"

# Revalidation Webhook Integration (Website details)
NEXT_PUBLIC_WEBSITE_URL="http://localhost:3000"
REVALIDATION_TOKEN="your_revalidation_token"

# Supabase Auth configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"
ADMIN_EMAIL="admin@csdashboard.com"
